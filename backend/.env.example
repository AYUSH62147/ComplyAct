# System
DEMO_MODE=true

# ─── GOOGLE CLOUD & GEMINI (Gemini Challenge Pivot) ────────────────
GOOGLE_API_KEY=your_gemini_api_key_here
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
AI_PROVIDER=GEMINI

# ─── AWS CREDENTIALS (Legacy / Dual-Stack) ─────────────────────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
